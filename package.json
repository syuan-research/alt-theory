{
  "name": "llm-theo",
  "version": "0.5.4",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:web": "tsx alt-theory-app/web-server/server.ts",
    "start:web": "tsx alt-theory-app/web-server/server.ts",
    "smoke:core": "tsx alt-theory-app/core/test-core.ts",
    "smoke:resume": "tsx alt-theory-app/core/smoke-resume.ts",
    "smoke:backend": "tsx alt-theory-app/web-server/smoke-backend.ts",
    "test:backend": "tsx --test alt-theory-app/**/*.test.ts",
    "dev:electron": "electron electron/main.cjs",
    "compile:bundle": "node scripts/compile-bundle.cjs",
    "build:electron": "npm run compile:bundle && electron-builder build --dir",
    "build:electron:portable": "npm run compile:bundle && electron-builder build --win portable"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "0.70.2",
    "@mariozechner/pi-coding-agent": "0.70.2",
    "@mariozechner/pi-web-ui": "0.70.2",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "mammoth": "^1.9.0",
    "marked": "^12.0.2",
    "multer": "^2.0.2",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5",
    "opencode-goal-plugin": "^0.1.10",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/ws": "^8.18.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.alttheory.app",
    "productName": "AltTheory",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**",
      "alt-theory-app/web-server/public/**",
      "dist-bundle/**",
      "agent-assets/**",
      "package.json",
      "node_modules/**"
    ],
    "asar": false,
    "win": {
      "target": [
        { "target": "dir", "arch": ["x64"] }
      ]
    },
    "portable": {
      "artifactName": "AltTheory-Portable-${version}.${ext}",
      "unpackDirName": "AltTheory",
      "splashImage": "build/splash.bmp"
    }
  }
}
