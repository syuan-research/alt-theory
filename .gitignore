# Git whitelist strategy: ignore root items with /*, then step-by-step unignore

# Ignore all top-level files and directories
/*

# Keep .gitignore itself
!.gitignore

# ========================================
# _dev directory
# ========================================
!_dev/

# Ignore everything in _dev except approaches
_dev/*
!_dev/approaches/

# Ignore everything in approaches except specific ones
_dev/approaches/*

# RAG approach (original)
!_dev/approaches/feature-rag-and-knowledge-base/
!_dev/approaches/feature-rag-and-knowledge-base/**

# PI agent harness approach (Phase 3: spec, plans, research, reviews)
!_dev/approaches/migrate-to-agent-harness-architecture/
!_dev/approaches/migrate-to-agent-harness-architecture/**

# ========================================
# alt-theory-rag (RAG server)
# ========================================
!alt-theory-rag/
!alt-theory-rag/**

# ========================================
# alt-theory-app (PI agent app)
# ========================================
!alt-theory-app/
!alt-theory-app/**

# Ignore node_modules inside alt-theory-app
alt-theory-app/**/node_modules/
alt-theory-app/**/node_modules/**
