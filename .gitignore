# Minimal explicit ignore policy.
#
# Default: track normal repository source, docs, architecture, curated assets,
# and config templates. Do not use .gitignore as a folder whitelist.

# Dependencies
node_modules/
**/node_modules/
.pnpm-store/
.yarn/
.npm/

# Build, cache, and test output
dist/
dist-bundle/
build/
out/
.cache/
coverage/
.next/
.vite/
*.tsbuildinfo

# Python/local tool caches
__pycache__/
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.py[cod]
.venv/
venv/

# Logs and scratch files
*.log
*.tmp
*.bak
tmp-*
.DS_Store
Thumbs.db

# Environment and credentials
.env
.env.*
!.env.example
!.env.template
auth.json
credentials.json
secrets.json
models.json
**/auth.json
**/credentials.json
**/secrets.json
**/models.json

# Local Alt Theory runtime/session data
/.alt-theory/
/alt-theory-data/
/data/sessions/
/data/history/
/data/records/
*.jsonl
!*.example.jsonl
!**/fixtures/**/*.jsonl

# Workstream-local test runs (dev-acceptance scripts, screenshots, logs)
/runs/
**/output/*-run-*/
/**/output/*-cdp/
/**/output/*-smoke-*/
server.log
server.log.err
playwright-mcp.log

# Private/raw research and user data
/private/
/project/private/
/raw-data/
/human-data/
/runs/raw/
/eval-runs/raw/

# Local snapshots and backups
/_archives/
