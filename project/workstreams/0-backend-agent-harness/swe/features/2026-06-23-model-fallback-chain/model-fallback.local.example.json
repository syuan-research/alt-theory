{
  "enabled": true,
  "provider": "qwen-bailian-beijing",
  "maxFallbacksPerRun": 8,
  "chain": [
    "qwen3.7-max-2026-05-20",
    "glm-5.1",
    "kimi-k2.6"
  ],
  "rules": [
    {
      "id": "auth-failure",
      "action": "fail",
      "match": {
        "anyPattern": [
          "401",
          "invalid api key",
          "incorrect api key",
          "authentication",
          "unauthorized"
        ]
      }
    },
    {
      "id": "dashscope-allocation-quota",
      "action": "exclude_and_fallback",
      "match": {
        "anyPattern": [
          "allocationquota",
          "free quota",
          "free tier",
          "free tier of the model",
          "quota has been exhausted",
          "quota exhausted",
          "tier exhausted",
          "insufficient quota"
        ]
      }
    }
  ]
}